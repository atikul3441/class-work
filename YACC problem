%{
#include <stdio.h>
#include <stdlib.h>
#include <ctype.h>

int yylex(void);
void yyerror(const char *message);

int error_found = 0;
%}

%union {
    int number;
}

%token <number> NUMBER
%type  <number> expression

/* Operator precedence */
%left '+' '-'
%left '*' '/' '%'
%right UMINUS

%%

input:
      expression '\n'
      {
          if (!error_found) {
              printf("Valid Arithmetic Expression\n");
              printf("Evaluated Value : %d\n", $1);
          }
      }
    ;

expression:
      NUMBER
      {
          $$ = $1;
      }
    | expression '+' expression
      {
          $$ = $1 + $3;
      }
    | expression '-' expression
      {
          $$ = $1 - $3;
      }
    | expression '*' expression
      {
          $$ = $1 * $3;
      }
    | expression '/' expression
      {
          if ($3 == 0) {
              yyerror("Division by zero");
              YYABORT;
          }

          $$ = $1 / $3;
      }
    | expression '%' expression
      {
          if ($3 == 0) {
              yyerror("Modulo by zero");
              YYABORT;
          }

          $$ = $1 % $3;
      }
    | '(' expression ')'
      {
          $$ = $2;
      }
    | '-' expression %prec UMINUS
      {
          $$ = -$2;
      }
    ;

%%

/* Simple lexical analyzer */
int yylex(void)
{
    int character;

    /* Ignore spaces and tabs */
    while ((character = getchar()) == ' ' || character == '\t') {
    }

    /* Read a number */
    if (isdigit(character)) {
        yylval.number = character - '0';

        while (isdigit(character = getchar())) {
            yylval.number =
                yylval.number * 10 + (character - '0');
        }

        if (character != EOF) {
            ungetc(character, stdin);
        }

        return NUMBER;
    }

    if (character == EOF) {
        return 0;
    }

    /* Return operators, parentheses, or newline */
    return character;
}

void yyerror(const char *message)
{
    if (!error_found) {
        printf("Invalid Arithmetic Expression\n");
        error_found = 1;
    }
}

int main(void)
{
    printf("Enter arithmetic expression: ");
    yyparse();

    return 0;
}



Compile and run

Using YACC:

yacc -d calculator.y
gcc y.tab.c -o calculator
./calculator


OR


Using Bison:

bison -d calculator.y
gcc calculator.tab.c -o calculator
./calculator
